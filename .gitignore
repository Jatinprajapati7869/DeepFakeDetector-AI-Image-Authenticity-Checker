# ── Runtime data (generated, not source) ────────────────────────────────────
backend/data/
backend/.pytest_cache/

# ── HuggingFace cache ────────────────────────────────────────────────────────
backend/weights/.cache/

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.env.local

# ── Jupyter ──────────────────────────────────────────────────────────────────
model_training/notebooks/.ipynb_checkpoints/
*.ipynb_checkpoints

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

