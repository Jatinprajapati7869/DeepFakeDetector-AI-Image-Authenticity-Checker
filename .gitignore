# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env
*.egg-info/
dist/
build/

# ── Model weights (large binary — downloaded at runtime from HuggingFace) ────
backend/weights/*.pth
backend/weights/*.pt
backend/weights/*.bin
