# Model
# Weights are downloaded automatically — see README for instructions
MODEL_PATH=./weights/best_model.pth
USE_MOCK_MODEL=false  # Set to true to skip model loading during development

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# Rate limiting
RATE_LIMIT_PER_MINUTE=10

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,https://deepfake-detector.vercel.app

# Storage
DATABASE_URL=sqlite+aiosqlite:///./data/history.db
HEATMAP_STORAGE_PATH=./data/heatmaps
