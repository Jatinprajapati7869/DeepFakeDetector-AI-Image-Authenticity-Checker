# Model mode
# DEMO_MODE=true keeps the app fully runnable without downloading model weights.
# Results in demo mode are deterministic simulations, not real forensic predictions.
DEMO_MODE=true
USE_MOCK_MODEL=true

# Real inference mode:
# 1. Download weights with: python download_model.py
# 2. Set DEMO_MODE=false and USE_MOCK_MODEL=false
MODEL_PATH=./weights/best_model.pth

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# Rate limiting
RATE_LIMIT_PER_MINUTE=10

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,https://deepfake-detector.vercel.app

# Storage
DATABASE_URL=sqlite+aiosqlite:///./data/history.db
HEATMAP_STORAGE_PATH=./data/heatmaps
